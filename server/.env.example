NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nail_app
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# File uploads
UPLOADS_DIR=./uploads

# CORS — * for all, or comma-separated origins
CORS_ORIGIN=*
